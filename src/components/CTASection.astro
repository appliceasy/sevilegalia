---
interface Props {
  title: string;
  text: string;
  buttonLabel: string;
  buttonHref: string;
  /** Tipografía más grande (p. ej. página de inicio) */
  prominent?: boolean;
}

const { title, text, buttonLabel, buttonHref, prominent = false } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const withBase = (path: string) =>
  `${baseUrl}${path.replace(/^\//, '')}`.replace(/(?<!:)\/{2,}/g, '/');
---

<section class="border-y border-neutral-border bg-neutral-surface" aria-labelledby="cta-titulo">
  <div class:list={['mx-auto max-w-content px-4 text-center sm:px-6 lg:px-8', prominent ? 'py-16 sm:py-20' : 'py-14']}>
    <h2
      id="cta-titulo"
      class:list={[
        'text-balance font-display font-bold text-primary',
        prominent ? 'text-3xl sm:text-4xl lg:text-[2.5rem]' : 'text-2xl sm:text-3xl',
      ]}
    >
      {title}
    </h2>
    <p
      class:list={[
        'mx-auto mt-4 max-w-2xl text-pretty leading-relaxed text-slate-600',
        prominent ? 'text-lg sm:text-xl' : '',
      ]}
    >
      {text}
    </p>
    <div class="mt-8 sm:mt-10">
      <a
        href={withBase(buttonHref)}
        class:list={[
          'inline-flex items-center justify-center rounded border-2 border-primary bg-primary font-heading font-semibold text-white shadow-sm transition duration-300 ease-smooth hover:-translate-y-0.5 hover:bg-primary-muted hover:shadow-md motion-reduce:transition-none motion-reduce:hover:translate-y-0 focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2',
          prominent ? 'px-10 py-4 text-base sm:text-lg' : 'px-8 py-3 text-sm',
        ]}
      >
        {buttonLabel}
      </a>
    </div>
  </div>
</section>
