---
const year = new Date().getFullYear();

const legal = [
  { href: '/legal/aviso-legal/', label: 'Aviso legal' },
  { href: '/legal/privacidad/', label: 'Política de privacidad' },
  { href: '/legal/cookies/', label: 'Política de cookies' },
];

const baseUrl = import.meta.env.BASE_URL;
const withBase = (path: string) =>
  `${baseUrl}${path.replace(/^\//, '')}`.replace(/(?<!:)\/{2,}/g, '/');
---

<footer class="border-t border-neutral-border bg-primary text-slate-300" role="contentinfo">
  <div class="mx-auto max-w-content px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-3">
      <div class="flex gap-3">
        <img
          src={withBase('/favicon.svg')}
          alt=""
          width="40"
          height="40"
          class="mt-1 h-10 w-10 shrink-0 opacity-90"
          decoding="async"
        />
        <div>
          <p class="font-display text-xl font-bold text-white">Sevilegalia</p>
          <p class="mt-2 max-w-sm text-sm leading-relaxed">
            Asesoramiento jurídico, fiscal y laboral para empresas, autónomos y particulares. Confianza, rigor y
            cercanía.
          </p>
        </div>
      </div>
      <div>
        <h2 class="font-heading text-sm font-semibold uppercase tracking-wider text-white">Enlaces</h2>
        <ul class="mt-4 space-y-2 text-sm">
          <li><a href={withBase('/despacho/')} class="hover:text-accent-highlight focus-visible:underline">Despacho</a></li>
          <li><a href={withBase('/servicios/')} class="hover:text-accent-highlight focus-visible:underline">Servicios</a></li>
          <li><a href={withBase('/contacto/')} class="hover:text-accent-highlight focus-visible:underline">Contacto</a></li>
        </ul>
      </div>
      <div>
        <h2 class="font-heading text-sm font-semibold uppercase tracking-wider text-white">Legal</h2>
        <ul class="mt-4 space-y-2 text-sm">
          {
            legal.map((item) => (
              <li>
                <a href={withBase(item.href)} class="hover:text-accent-highlight focus-visible:underline">
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
    <div class="mt-10 border-t border-white/10 pt-8 text-center text-xs text-slate-500">
      <p>© {year} Sevilegalia. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>
