---
/**
 * Hero de inicio: pantalla completa con vídeo o solo imagen de fondo, o diseño clásico imagen + texto.
 * Respeta prefers-reduced-motion (vídeo oculto si el usuario lo pide).
 */
interface Props {
  title: string;
  subtitle: string;
  ctaLabel: string;
  ctaHref: string;
  imageSrc: string;
  imageAlt: string;
  imageLoading?: 'eager' | 'lazy';
  /** Vídeo local o CDN: hero a pantalla completa; `imageSrc` sirve de poster y fallback con movimiento reducido */
  videoSrc?: string;
  /** Pantalla completa solo con imagen (sin vídeo). Ideal para archivos en `/public/`. */
  fullBleedImage?: boolean;
  /** Imagen opcional a la derecha del bloque de texto (p. ej. logo sin fondo), solo en modo cinematográfico */
  asideImageSrc?: string;
  asideImageAlt?: string;
}

const {
  title,
  subtitle,
  ctaLabel,
  ctaHref,
  imageSrc,
  imageAlt,
  imageLoading = 'lazy',
  videoSrc,
  fullBleedImage = false,
  asideImageSrc,
  asideImageAlt = '',
} = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const withBase = (path: string) =>
  path.startsWith('http://') || path.startsWith('https://')
    ? path
    : `${baseUrl}${path.replace(/^\//, '')}`.replace(/(?<!:)\/{2,}/g, '/');

const showVideo = Boolean(videoSrc);
const cinematic = showVideo || fullBleedImage;
---

{
  cinematic ? (
    <section
      class="relative flex min-h-[72vh] items-center overflow-hidden sm:min-h-[78vh] lg:min-h-[82vh]"
      aria-labelledby="hero-titulo"
    >
      <div class="absolute inset-0 z-0" aria-hidden="true">
        {
          showVideo ? (
            <>
              <img
                src={withBase(imageSrc)}
                alt=""
                width={1920}
                height={1080}
                loading="eager"
                decoding="async"
                class="pointer-events-none absolute inset-0 hidden h-full w-full scale-105 object-cover motion-reduce:block"
              />
              <video
                data-hero-video
                class="pointer-events-none absolute inset-0 h-full w-full object-cover motion-reduce:hidden"
                autoplay
                muted
                loop
                playsinline
                preload="metadata"
                poster={withBase(imageSrc)}
              >
                <source src={withBase(videoSrc!)} type="video/mp4" />
              </video>
            </>
          ) : (
            <img
              src={withBase(imageSrc)}
              alt=""
              width={1920}
              height={1080}
              loading="eager"
              decoding="async"
              class="pointer-events-none absolute inset-0 h-full w-full scale-105 object-cover"
            />
          )
        }
        <div
          class="pointer-events-none absolute inset-0 bg-gradient-to-br from-primary-dark via-primary to-[#0d4a40] opacity-50"
          aria-hidden="true"
        />
      </div>

      <div class="relative z-10 mx-auto w-full max-w-content px-4 py-20 sm:px-6 sm:py-24 lg:px-8">
        <div
          class:list={[
            asideImageSrc &&
              'grid grid-cols-1 gap-y-5 lg:grid-cols-2 lg:items-start lg:gap-x-10 lg:gap-y-0 xl:gap-x-14',
          ]}
        >
          <div class:list={['hero-enter max-w-3xl', asideImageSrc && 'lg:max-w-none']}>
            <p class="font-heading text-sm font-semibold uppercase tracking-[0.2em] text-accent-highlight/90 motion-reduce:opacity-100 sm:text-base sm:tracking-[0.22em]">
              Sevilegalia
            </p>
            <h1
              id="hero-titulo"
              class="mt-4 text-balance font-display text-4xl font-bold leading-[1.12] text-white sm:text-5xl sm:leading-[1.1] lg:text-[2.875rem] lg:leading-[1.08] xl:text-6xl"
            >
              {title}
            </h1>
            <p class="mt-6 max-w-2xl text-lg leading-relaxed text-slate-100 sm:text-xl sm:leading-relaxed">
              {subtitle}
            </p>
            <div class="mt-10 sm:mt-12">
              <a
                href={withBase(ctaHref)}
                class="hero-cta inline-flex min-h-[3rem] items-center justify-center rounded-md bg-white px-8 py-3.5 font-heading text-base font-semibold text-primary shadow-lg transition duration-300 ease-out hover:-translate-y-0.5 hover:bg-slate-100 hover:shadow-xl focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white sm:min-h-[3.25rem] sm:px-10 sm:text-lg"
              >
                {ctaLabel}
              </a>
            </div>
          </div>
          {
            asideImageSrc && (
              <div class="-mt-1 flex justify-center self-start sm:-mt-2 lg:-mt-10 lg:justify-end xl:-mt-12">
                <img
                  src={withBase(asideImageSrc)}
                  alt={asideImageAlt}
                  width={560}
                  height={420}
                  loading="eager"
                  decoding="async"
                  class="h-auto w-full max-w-sm object-contain object-top drop-shadow-[0_8px_32px_rgba(0,0,0,0.25)] sm:max-w-md lg:max-w-lg"
                />
              </div>
            )
          }
        </div>
      </div>
    </section>
  ) : (
    <section class="relative overflow-hidden bg-brand-gradient" aria-labelledby="hero-titulo">
      <div class="mx-auto grid max-w-content gap-8 px-4 py-16 sm:px-6 lg:grid-cols-2 lg:items-center lg:gap-12 lg:py-24 lg:px-8">
        <div class="relative z-10">
          <h1
            id="hero-titulo"
            class="text-balance font-display text-3xl font-bold leading-tight text-white sm:text-4xl lg:text-5xl"
          >
            {title}
          </h1>
          <p class="mt-4 max-w-xl text-lg text-slate-300">{subtitle}</p>
          <div class="mt-8">
            <a
              href={withBase(ctaHref)}
              class="inline-flex items-center justify-center rounded bg-accent px-6 py-3 font-heading text-sm font-semibold text-white shadow-md transition duration-300 ease-out hover:-translate-y-0.5 hover:bg-accent-soft focus-visible:ring-2 focus-visible:ring-accent-highlight focus-visible:ring-offset-2 focus-visible:ring-offset-primary-dark"
            >
              {ctaLabel}
            </a>
          </div>
        </div>
        <div class="relative">
          <div class="aspect-[4/3] overflow-hidden rounded-lg shadow-card ring-1 ring-white/10 transition duration-500 ease-out hover:ring-white/20">
            <img
              src={withBase(imageSrc)}
              alt={imageAlt}
              width={800}
              height={600}
              loading={imageLoading}
              decoding="async"
              class="h-full w-full object-cover transition duration-700 ease-out hover:scale-[1.02]"
            />
          </div>
        </div>
      </div>
    </section>
  )
}

{cinematic && (
  <style>
    @keyframes hero-enter {
      from {
        opacity: 0;
        transform: translate3d(0, 1.25rem, 0);
      }
      to {
        opacity: 1;
        transform: translate3d(0, 0, 0);
      }
    }
    .hero-enter {
      animation: hero-enter 0.85s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }
    @media (prefers-reduced-motion: reduce) {
      .hero-enter {
        animation: none;
        opacity: 1;
        transform: none;
      }
    }
  </style>
)}
