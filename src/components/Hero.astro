---
interface Props {
  title: string;
  subtitle: string;
  ctaLabel: string;
  ctaHref: string;
  imageSrc: string;
  imageAlt: string;
  imageLoading?: 'eager' | 'lazy';
}

const {
  title,
  subtitle,
  ctaLabel,
  ctaHref,
  imageSrc,
  imageAlt,
  imageLoading = 'lazy',
} = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const withBase = (path: string) =>
  path.startsWith('http://') || path.startsWith('https://')
    ? path
    : `${baseUrl}${path.replace(/^\//, '')}`.replace(/(?<!:)\/{2,}/g, '/');
---

<section
  class="relative overflow-hidden bg-brand-gradient"
  aria-labelledby="hero-titulo"
>
  <div class="mx-auto grid max-w-content gap-8 px-4 py-16 sm:px-6 lg:grid-cols-2 lg:items-center lg:gap-12 lg:py-24 lg:px-8"
  >
    <div class="relative z-10">
      <h1 id="hero-titulo" class="font-display text-3xl font-bold leading-tight text-white sm:text-4xl lg:text-5xl">
        {title}
      </h1>
      <p class="mt-4 max-w-xl text-lg text-slate-300">{subtitle}</p>
      <div class="mt-8">
        <a
          href={withBase(ctaHref)}
          class="inline-flex items-center justify-center rounded bg-accent px-6 py-3 font-heading text-sm font-semibold text-white shadow-md transition hover:bg-accent-soft focus-visible:ring-2 focus-visible:ring-accent-highlight focus-visible:ring-offset-2 focus-visible:ring-offset-primary-dark"
        >
          {ctaLabel}
        </a>
      </div>
    </div>
    <div class="relative">
      <div class="aspect-[4/3] overflow-hidden rounded-lg shadow-card ring-1 ring-white/10">
        <img
          src={imageSrc}
          alt={imageAlt}
          width={800}
          height={600}
          loading={imageLoading}
          decoding="async"
          class="h-full w-full object-cover"
        />
      </div>
    </div>
  </div>
</section>
