---
interface Props {
  title: string;
  description: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const { title, description, ctaLabel = 'Contactar', ctaHref = '/contacto' } = Astro.props;
---

<article
  class="flex h-full flex-col rounded-lg border border-neutral-border bg-white p-6 shadow-card transition hover:border-accent/30 hover:shadow-lg"
>
  <h3 class="font-heading text-lg font-semibold text-primary">{title}</h3>
  <p class="mt-3 flex-grow text-sm leading-relaxed text-slate-600">{description}</p>
  <div class="mt-6">
    <a
      href={ctaHref}
      class="inline-flex items-center font-heading text-sm font-semibold text-accent hover:text-accent-soft"
    >
      {ctaLabel}
      <span class="ml-1" aria-hidden="true">→</span>
    </a>
  </div>
</article>
