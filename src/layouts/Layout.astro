---
import Analytics from '@/components/Analytics.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';

interface Props {
  /** Título único por página (SEO) */
  title: string;
  /** Meta description (SEO) */
  description: string;
  /** Ruta canónica relativa, ej. /contacto */
  canonicalPath?: string;
}

const { title, description, canonicalPath = Astro.url.pathname } = Astro.props;

const siteUrl = Astro.site?.href.replace(/\/$/, '') ?? '';
const canonical = `${siteUrl}${canonicalPath === '/' ? '' : canonicalPath}` || undefined;
const fullTitle = title.includes('|') ? title : `${title} | Sevilegalia`;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#07404E" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" sizes="any" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}
    <meta name="robots" content="index, follow" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    {canonical && <meta property="og:url" content={canonical} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:wght@600;700&family=Poppins:wght@500;600;700&family=Roboto:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen bg-white font-body text-slate-800 antialiased">
    <a
      href="#contenido-principal"
      class="focus:bg-accent focus:text-white sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[100] focus:rounded focus:px-4 focus:py-2"
      >Saltar al contenido</a
    >
    <Header />
    <main id="contenido-principal" tabindex="-1">
      <slot />
    </main>
    <Footer />
    <Analytics />
  </body>
</html>

<style is:global>
  :focus-visible {
    outline: 2px solid #145c46;
    outline-offset: 2px;
  }
</style>
