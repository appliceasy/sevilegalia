---
import Layout from '@/layouts/Layout.astro';
import ContactForm from '@/components/ContactForm.astro';

const meta = {
  title: 'Contacto',
  description:
    'Contacte con Sevilegalia para solicitar una consulta. Formulario de contacto y datos del despacho (sitio informativo).',
};

const contactoImage =
  'https://images.unsplash.com/photo-1521791136064-7986c2920216?auto=format&fit=crop&w=1200&q=80';
---

<Layout title={meta.title} description={meta.description} canonicalPath="/contacto">
  <div class="border-b border-neutral-border bg-neutral-surface">
    <div class="mx-auto max-w-content px-4 py-14 sm:px-6 lg:px-8">
      <h1 class="font-display text-4xl font-bold text-primary">Contacto</h1>
      <p class="mt-4 max-w-2xl text-lg text-slate-600">
        Estamos a su disposición para concertar una primera reunión o resolver dudas iniciales sobre su caso.
      </p>
    </div>
  </div>

  <div class="mx-auto max-w-content px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid gap-12 lg:grid-cols-2 lg:items-start">
      <div>
        <div class="overflow-hidden rounded-lg shadow-card ring-1 ring-slate-200/80">
          <img
            src={contactoImage}
            alt="Manos estrechándose en acuerdo profesional tras reunión de negocios"
            width={900}
            height={600}
            loading="lazy"
            decoding="async"
            class="h-full w-full object-cover"
          />
        </div>
        <div class="mt-8 rounded-lg border border-neutral-border bg-neutral-surface p-6">
          <h2 class="font-heading text-lg font-semibold text-primary">Datos del despacho</h2>
          <address class="mt-4 not-italic text-sm leading-relaxed text-slate-600">
            <p class="font-medium text-slate-800">Sevilegalia Asesoría Jurídica</p>
            <p>Calle Ejemplo, 123, 4.º B</p>
            <p>28001 Madrid, España</p>
            <p class="mt-3">
              <span class="sr-only">Teléfono: </span>
              <a href="tel:+34900000000" class="text-accent hover:underline">+34 900 000 000</a>
            </p>
            <p>
              <span class="sr-only">Email: </span>
              <a href="mailto:info@ejemplo-despacho.es" class="text-accent hover:underline">info@ejemplo-despacho.es</a>
            </p>
          </address>
          <p class="mt-4 text-xs text-slate-500">
            Horario de atención telefónica: lunes a viernes, 9:00–18:00 (placeholder).
          </p>
        </div>
      </div>
      <ContactForm />
    </div>
  </div>
</Layout>
