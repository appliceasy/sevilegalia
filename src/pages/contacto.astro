---
import Layout from '@/layouts/Layout.astro';
import ContactForm from '@/components/ContactForm.astro';

const meta = {
  title: 'Contacto',
  description:
    'Contacta con SeviLegalia. Formulario y ubicación del despacho en Sevilla. Primera consulta gratuita.',
};

const baseUrl = import.meta.env.BASE_URL;
const withBase = (path: string) =>
  `${baseUrl}${path.replace(/^\//, '')}`.replace(/(?<!:)\/{2,}/g, '/');

const contactoImage = '/Imagen_secundaria.png';
---

<Layout title={meta.title} description={meta.description} canonicalPath="/contacto/">
  <div class="border-b border-neutral-border bg-neutral-surface">
    <div class="mx-auto max-w-content px-4 py-14 sm:px-6 lg:px-8">
      <h1 class="font-display text-4xl font-bold text-primary">Contacto</h1>
      <p class="mt-4 max-w-2xl text-lg text-slate-600">
        Estamos a tu disposición para resolver dudas o concertar una primera reunión.
      </p>
    </div>
  </div>

  <div class="mx-auto max-w-content px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid gap-12 lg:grid-cols-2 lg:items-start">
      <div>
        <div class="overflow-hidden rounded-lg shadow-card ring-1 ring-slate-200/80">
          <img
            src={withBase(contactoImage)}
            alt="Escritorio jurídico profesional en el despacho SeviLegalia"
            width={900}
            height={600}
            loading="lazy"
            decoding="async"
            class="h-full w-full object-cover"
          />
        </div>
        <div class="mt-8 rounded-lg border border-neutral-border bg-neutral-surface p-6">
          <h2 class="font-heading text-lg font-semibold text-primary">¿Dónde nos encontramos?</h2>
          <address class="mt-4 not-italic text-sm leading-relaxed text-slate-600">
            <p>C. Progreso, 20, 2ºA</p>
            <p>41013 Sevilla</p>
            <p class="mt-3">
              <span class="sr-only">Email: </span>
              <a href="mailto:info@sevilegalia.com" class="text-accent hover:underline">info@sevilegalia.com</a>
            </p>
          </address>
          <p class="mt-4 text-xs text-slate-500">
            Horario de atención al cliente: lunes a viernes, 9:00–18:00.
          </p>
        </div>
      </div>
      <ContactForm />
    </div>
  </div>
</Layout>
