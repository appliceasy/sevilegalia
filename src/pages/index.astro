---
import Layout from '@/layouts/Layout.astro';
import Hero from '@/components/Hero.astro';
import CTASection from '@/components/CTASection.astro';
import ValoresSection from '@/components/ValoresSection.astro';

const meta = {
  title: 'Inicio',
  description:
    'Despacho en Sevilla: asesoramiento civil, laboral y más. Más de 20 años de experiencia, explicada con claridad. Primera consulta gratuita.',
};

const baseUrl = import.meta.env.BASE_URL;
const withBase = (path: string) =>
  `${baseUrl}${path.replace(/^\//, '')}`.replace(/(?<!:)\/{2,}/g, '/');

/** Hero: vídeo en bucle (`public/`) + imagen como poster y fallback sin autoplay */
const heroImage = '/fondo_hero.png';
const heroVideo = '/video_corto.mp4';
const serviciosImage = '/Imagen_secundaria.png';

const valores = [
  {
    titulo: 'Trato directo',
    texto:
      'Hablas con el letrado que lleva tu asunto, sin intermediarios. La comunicación va contigo, con detalle y continuidad.',
  },
  {
    titulo: 'Compromiso con tu caso',
    texto:
      'Lo que nos confías nos importa: dedicación y rigor en cada paso, desde la primera consulta hasta la resolución.',
  },
  {
    titulo: 'Presencial u online',
    texto:
      'Citamos en el despacho o por medios telemáticos, según tu disponibilidad. Respuesta clara sin complicarte la agenda.',
  },
];
---

<Layout title={meta.title} description={meta.description} canonicalPath="/">
  <Hero
    title="Soluciones jurídicas y asesoramiento integral para empresas y particulares"
    subtitle="Más de 20 años asesorando a empresas y particulares: criterio jurídico, lenguaje comprensible y un trato cercano desde el primer día."
    ctaLabel="Contacta con nosotros"
    ctaHref="/contacto/"
    imageSrc={heroImage}
    imageAlt="Despacho jurídico Sevilegalia: sala de reuniones y símbolos de la profesión"
    imageLoading="eager"
    videoSrc={heroVideo}
    asideImageSrc="/Sevilegalia.png"
    asideImageAlt="Sevilegalia"
  />

  <ValoresSection valores={valores} />

  <section
    class="reveal-section relative overflow-hidden bg-white py-20 shadow-[inset_0_1px_0_0_rgba(7,64,78,0.06)] sm:py-24 lg:py-28"
    data-reveal
    aria-labelledby="servicios-destacados-titulo"
  >
    <div
      class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-primary/15 to-transparent"
      aria-hidden="true"
    >
    </div>
    <div
      class="pointer-events-none absolute -left-20 bottom-0 h-64 w-64 rounded-full bg-primary/[0.06] blur-3xl sm:-left-28 sm:h-80 sm:w-80"
      aria-hidden="true"
    >
    </div>

    <div class="relative mx-auto max-w-content px-4 sm:px-6 lg:px-8">
      <div class="mx-auto mb-14 max-w-3xl text-center sm:mb-16">
        <p
          class="font-heading text-sm font-semibold uppercase tracking-[0.18em] text-accent sm:text-base sm:tracking-[0.2em]"
        >
          Servicios y ámbitos
        </p>
        <div
          class="mx-auto mt-4 h-1 w-14 rounded-full bg-gradient-to-r from-primary via-accent to-primary-muted sm:w-16"
          aria-hidden="true"
        >
        </div>
        <h2
          id="servicios-destacados-titulo"
          class="mt-5 text-balance font-display text-4xl font-bold leading-tight text-primary sm:text-5xl"
        >
          En qué podemos ayudarte
        </h2>
      </div>

      <div class="grid gap-12 lg:grid-cols-2 lg:items-start lg:gap-14">
        <div
          class="rounded-3xl border border-neutral-border bg-neutral-surface/90 p-8 shadow-card ring-1 ring-primary/[0.04] sm:p-10"
        >
          <div class="space-y-8 text-base text-slate-600 sm:text-lg">
            <div>
              <h3 class="font-heading text-xl font-semibold text-primary sm:text-2xl">Derecho civil y propiedad</h3>
              <ul class="mt-4 list-disc space-y-2.5 pl-6 leading-relaxed">
                <li>
                  <strong class="text-slate-800">Derecho Inmobiliario y Urbanístico:</strong> Soluciones expertas para tu
                  vivienda y propiedades.
                </li>
                <li><strong class="text-slate-800">Herencias.</strong></li>
                <li>
                  <strong class="text-slate-800">Divorcios:</strong> Gestión profesional y sensible de tus procesos
                  familiares.
                </li>
              </ul>
            </div>

            <div>
              <h3 class="font-heading text-xl font-semibold text-primary sm:text-2xl">Derecho laboral</h3>
              <ul class="mt-4 list-disc space-y-2.5 pl-6 leading-relaxed">
                <li>
                  <strong class="text-slate-800">Despidos.</strong> Analizamos si un despido es improcedente o nulo.
                </li>
                <li><strong class="text-slate-800">Revisión de nóminas y contratos.</strong></li>
                <li>
                  <strong class="text-slate-800">Reclamaciones de cantidad:</strong> Asesoramiento directo para recuperar
                  lo que te corresponde.
                </li>
              </ul>
            </div>

            <div>
              <h3 class="font-heading text-xl font-semibold text-primary sm:text-2xl">Plan Tranquilidad</h3>
              <p class="mt-4 leading-relaxed">
                Cuota mensual (desde 25€) con consultas para cubrir dudas jurídicas del día a día con un profesional de
                confianza.
              </p>
            </div>

            <div>
              <h3 class="font-heading text-xl font-semibold text-primary sm:text-2xl">
                Otros asuntos en los que podemos ayudarte
              </h3>
              <ul class="mt-4 list-disc space-y-2.5 pl-6 leading-relaxed">
                <li>
                  <strong class="text-slate-800">Contratos:</strong> Redacción y supervisión de acuerdos laborales,
                  mercantiles o civiles.
                </li>
                <li>
                  <strong class="text-slate-800">Reclamaciones Bancarias:</strong> Nulidad de tarjetas revolving y
                  cláusulas de préstamos hipotecarios.
                </li>
                <li>
                  <strong class="text-slate-800">Prestaciones:</strong> Solicitud del Complemento de Paternidad o Brecha de
                  Género.
                </li>
                <li>
                  <strong class="text-slate-800">Extranjería:</strong> Gestión de nacionalidad, permisos de residencia y
                  renovaciones.
                </li>
                <li><strong class="text-slate-800">Asesoría:</strong> Soporte especializado en materia fiscal y contable.</li>
              </ul>
            </div>
          </div>
        </div>
        <div class="overflow-hidden rounded-lg shadow-card ring-1 ring-slate-200/80 transition-shadow duration-layout ease-smooth hover:shadow-card-hover lg:sticky lg:top-28">
          <img
            src={withBase(serviciosImage)}
            alt="Detalle de escritorio jurídico: documentos y balanza de la justicia"
            width={800}
            height={600}
            loading="lazy"
            decoding="async"
            class="h-full w-full object-cover transition duration-700 ease-smooth motion-reduce:transition-none hover:scale-[1.02] motion-reduce:hover:scale-100"
          />
        </div>
      </div>
    </div>
  </section>

  <div data-reveal class="reveal-section">
    <CTASection
      title="¿Hablamos de tu caso?"
      text="Primera consulta sin coste. Cuéntanos la situación y te orientamos con claridad; te responderemos lo antes posible."
      buttonLabel="Contacta con nosotros"
      buttonHref="/contacto/"
      prominent
    />
  </div>
</Layout>
