---
import Layout from '@/layouts/Layout.astro';

const meta = {
  title: 'Servicios',
  description:
    'Servicios jurídicos personalizados: civil, laboral, segunda oportunidad, Plan Tranquilidad, penal y compliance, extranjería y más. SeviLegalia.',
};
const baseUrl = import.meta.env.BASE_URL;
const withBase = (path: string) =>
  `${baseUrl}${path.replace(/^\//, '')}`.replace(/(?<!:)\/{2,}/g, '/');
---

<Layout title={meta.title} description={meta.description} canonicalPath="/servicios/">
  <div class="border-b border-neutral-border bg-neutral-surface">
    <div class="mx-auto max-w-content px-4 py-14 sm:px-6 lg:px-8">
      <h1 class="font-display text-4xl font-bold text-primary">Servicios</h1>
      <p class="mt-4 max-w-3xl font-heading text-xl font-semibold tracking-tight text-slate-700 sm:text-2xl">
        Prácticas habituales, trato a medida
      </p>
      <p class="mt-6 max-w-3xl text-lg leading-relaxed text-slate-600">
        Aquí tienes un mapa de lo que solemos hacer. Si tu asunto no encaja en una casilla, igualmente
        cuéntanoslo: la primera consulta es gratuita y te diremos si podemos ayudarte y cómo.
      </p>
    </div>
  </div>

  <div class="mx-auto max-w-content space-y-14 px-4 py-16 sm:px-6 lg:px-8">
    <section class="scroll-mt-24" aria-labelledby="servicio-civil" id="civil">
      <div class="rounded-xl border border-neutral-border bg-white p-8 shadow-card sm:p-10">
        <h2 id="servicio-civil" class="font-display text-2xl font-bold text-primary sm:text-3xl">
          Derecho civil y propiedad
        </h2>
        <ul class="mt-6 list-disc space-y-3 pl-5 text-slate-600">
          <li>
            <strong class="text-slate-800">Defensa ante la banca:</strong> Revisión y reclamación de cláusulas abusivas
            en préstamos hipotecarios, gastos y tarjetas revolving.
          </li>
          <li>
            <strong class="text-slate-800">Herencias y sucesiones:</strong> Gestión integral y sensible de sucesiones y
            herencias.
          </li>
          <li>
            <strong class="text-slate-800">Derecho inmobiliario y urbanístico:</strong> Soluciones en propiedad
            horizontal, conflictos vecinales y vicios ocultos.
          </li>
          <li>
            <strong class="text-slate-800">Divorcios:</strong> Acompañamiento profesional en procesos de ruptura
            familiar.
          </li>
        </ul>
      </div>
    </section>

    <section class="scroll-mt-24" aria-labelledby="servicio-laboral" id="laboral">
      <div class="rounded-xl border border-neutral-border bg-white p-8 shadow-card sm:p-10">
        <h2 id="servicio-laboral" class="font-display text-2xl font-bold text-primary sm:text-3xl">Derecho laboral</h2>
        <ul class="mt-6 list-disc space-y-3 pl-5 text-slate-600">
          <li>
            <strong class="text-slate-800">Despidos y extinciones:</strong> Asesoramiento y representación en
            procedimientos de despido.
          </li>
          <li>
            <strong class="text-slate-800">Reclamación de cantidad:</strong> Recuperación de salarios e indemnizaciones
            pendientes.
          </li>
          <li>
            <strong class="text-slate-800">Revisión de nóminas y contratos:</strong> Análisis para garantizar que tu
            documentación laboral cumple con la ley.
          </li>
        </ul>
      </div>
    </section>

    <section class="scroll-mt-24" aria-labelledby="servicio-segunda-oportunidad" id="segunda-oportunidad">
      <div class="rounded-xl border border-neutral-border bg-white p-8 shadow-card sm:p-10">
        <h2 id="servicio-segunda-oportunidad" class="font-display text-2xl font-bold text-primary sm:text-3xl">
          Ley de la segunda oportunidad (exoneración de deudas)
        </h2>
        <ul class="mt-6 list-disc space-y-3 pl-5 text-slate-600">
          <li>
            <strong class="text-slate-800">Especialistas en procesos concursales:</strong> Gestionamos concursos con y sin
            masa para personas físicas (particulares/autónomos) y mercantiles.
          </li>
          <li>
            <strong class="text-slate-800">Soluciones a medida:</strong> Tramitación de planes de pagos para proteger
            activos o solicitud del EPI (exoneración del pasivo insatisfecho) para la cancelación total de deudas.
          </li>
          <li>
            <strong class="text-slate-800">Gestión integral:</strong> Te defendemos en cualquier fase del procedimiento
            para que logres un nuevo comienzo financiero.
          </li>
        </ul>
      </div>
    </section>

    <section class="scroll-mt-24" aria-labelledby="servicio-plan-tranquilidad" id="plan-tranquilidad">
      <div class="rounded-xl border border-neutral-border bg-white p-8 shadow-card sm:p-10">
        <h2 id="servicio-plan-tranquilidad" class="font-display text-2xl font-bold text-primary sm:text-3xl">
          Plan Tranquilidad (suscripción)
        </h2>
        <ul class="mt-6 list-disc space-y-3 pl-5 text-slate-600">
          <li><strong class="text-slate-800">Protección legal continua por 25€/mes.</strong></li>
          <li>
            <strong class="text-slate-800">Consultas ilimitadas:</strong> Resolución inmediata de dudas jurídicas para
            tu día a día.
          </li>
          <li>
            <strong class="text-slate-800">Revisión de contratos:</strong> Análisis preventivo de cualquier documento
            antes de firmar.
          </li>
        </ul>
      </div>
    </section>

    <section class="scroll-mt-24" aria-labelledby="servicio-penal" id="penal">
      <div class="rounded-xl border border-neutral-border bg-white p-8 shadow-card sm:p-10">
        <h2 id="servicio-penal" class="font-display text-2xl font-bold text-primary sm:text-3xl">
          Derecho penal y compliance socioeconómico
        </h2>
        <p class="mt-4 leading-relaxed text-slate-600">
          Ofrecemos una defensa técnica rigurosa y especializada en delitos que afectan al ámbito patrimonial y a la
          actividad empresarial. Nos centramos en la protección de la libertad y el honor, con especial énfasis en el
          derecho penal económico:
        </p>
        <ul class="mt-6 list-disc space-y-3 pl-5 text-slate-600">
          <li>
            <strong class="text-slate-800">Delitos socioeconómicos:</strong> Defensa y acusación en procedimientos por
            estafas, apropiaciones indebidas, administración desleal y delitos contra el patrimonio.
          </li>
          <li>
            <strong class="text-slate-800">Derecho penal de la empresa:</strong> Asesoramiento especializado en
            insolvencias punibles, delitos contra la Hacienda Pública y la Seguridad Social, y delitos contra los derechos
            de los trabajadores.
          </li>
          <li>
            <strong class="text-slate-800">Responsabilidad penal de las personas jurídicas:</strong> Ayudamos a empresas y
            directivos a prevenir riesgos penales derivados de su actividad mercantil.
          </li>
          <li>
            <strong class="text-slate-800">Defensa general:</strong> Asistencia al detenido e intervención en todas las
            fases del proceso penal, desde la instrucción hasta el juicio oral.
          </li>
        </ul>
      </div>
    </section>

    <section class="scroll-mt-24" aria-labelledby="servicio-otros" id="otros">
      <div class="rounded-xl border border-neutral-border bg-white p-8 shadow-card sm:p-10">
        <h2 id="servicio-otros" class="font-display text-2xl font-bold text-primary sm:text-3xl">
          Otros servicios especializados
        </h2>
        <ul class="mt-6 list-disc space-y-3 pl-5 text-slate-600">
          <li>
            <strong class="text-slate-800">Extranjería:</strong> Permisos de residencia, nacionalidad y renovaciones.
          </li>
          <li>
            <strong class="text-slate-800">Brecha de género:</strong> Reclamación del complemento de paternidad en
            pensiones con alta tasa de éxito.
          </li>
          <li>
            <strong class="text-slate-800">Asesoría fiscal y contable:</strong> Soporte especializado para el cumplimiento
            tributario de autónomos y pymes.
          </li>
        </ul>
        <div class="mt-10">
          <a
            href={withBase('/contacto/')}
            class="inline-flex items-center justify-center rounded bg-accent px-6 py-3 font-heading text-sm font-semibold text-white transition hover:bg-accent-soft focus-visible:ring-2 focus-visible:ring-offset-2"
          >
            Contacta con nosotros
          </a>
        </div>
      </div>
    </section>
  </div>
</Layout>
